{
	"version": 3,
	"configurePresets": [
		{
			"name": "default",
			"displayName": "Default",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build"
		},
		{
			"name": "release",
			"displayName": "Release",
			"inherits": "default",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release"
			}
		}
	]
}
